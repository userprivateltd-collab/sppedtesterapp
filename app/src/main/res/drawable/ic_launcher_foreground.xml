<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer Glow/Shadow for the gauge -->
    <path
        android:pathData="M30,70 A35,35 0 1 1 78,70"
        android:strokeWidth="12"
        android:strokeLineCap="round"
        android:strokeColor="#2200E5FF"/>

    <!-- Main Cyan Arc -->
    <path
        android:pathData="M30,70 A35,35 0 1 1 78,70"
        android:strokeWidth="6"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="30"
                android:startY="70"
                android:endX="78"
                android:endY="70"
                android:type="linear">
                <item android:offset="0" android:color="#00E5FF" />
                <item android:offset="1" android:color="#D500F9" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Speed Pulse (Needle/Spark) -->
    <path
        android:pathData="M70,45 L85,35"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeColor="#FFFFFF" />

    <!-- Center stylized 'K' or lightning -->
    <path
        android:pathData="M48,40 L60,54 L48,54 L60,68"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeColor="#00E5FF" />

</vector>
